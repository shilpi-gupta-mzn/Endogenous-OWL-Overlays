@prefix : <http://example.org/scenario1#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://example.org/scenario1> rdf:type owl:Ontology .

:Entity rdf:type owl:Class .
:Categorization rdf:type owl:Class .
:Intercalation rdf:type owl:Class .
:Relationship rdf:type owl:Class .
:Participation rdf:type owl:Class .
:Marker rdf:type owl:Class .

:hasCustodian rdf:type owl:ObjectProperty .
:hasTag rdf:type owl:ObjectProperty .
:involvesType rdf:type owl:ObjectProperty .
:isConnectedTo rdf:type owl:ObjectProperty .
:hasName rdf:type owl:ObjectProperty .
:hasDeclaredType rdf:type owl:ObjectProperty .
:refersTo rdf:type owl:ObjectProperty .

:hasParent rdf:type owl:ObjectProperty .
:hasFather rdf:type owl:ObjectProperty .

:Person rdf:type :Entity .
:MalePerson rdf:type :Entity .
:GrantPlinth rdf:type :Entity .
:MrPlinth rdf:type :Entity .

:C1 rdf:type :Categorization .

:I1 rdf:type :Intercalation ;
    :hasCustodian :C1 ;
    :hasTag :Specialization ;
    :involvesType :MalePerson .

:I2 rdf:type :Intercalation ;
    :hasCustodian :C1 ;
    :hasTag :Generalization ;
    :involvesType :Person .

:R1 rdf:type :Relationship .

:P1 rdf:type :Participation ;
    :hasCustodian :R1 ;
    :isConnectedTo :Person ;
    :hasName :hasParent .

:P2 rdf:type :Participation ;
    :hasCustodian :R1 ;
    :isConnectedTo :Person ;
    :hasName :Undefined .

:R2 rdf:type :Relationship .

:P3 rdf:type :Participation ;
    :hasCustodian :R2 ;
    :isConnectedTo :MalePerson ;
    :hasName :hasFather .

:P4 rdf:type :Participation ;
    :hasCustodian :R2 ;
    :isConnectedTo :Person ;
    :hasName :Undefined .

:M rdf:type :Marker ;
    :hasTag :SubsetOf ;
    :hasCustodian :hasFather ;
    :refersTo :hasParent .

:GrantPlinth :hasDeclaredType :MalePerson .
:MrPlinth :hasDeclaredType :MalePerson .

:R3 rdf:type :Relationship .

:P5 rdf:type :Participation ;
    :hasCustodian :R3 ;
    :isConnectedTo :MrPlinth ;
    :hasName :hasFather .

:P6 rdf:type :Participation ;
    :hasCustodian :R3 ;
    :isConnectedTo :GrantPlinth ;
    :hasName :Undefined .

:MrPlinth rdf:type :MalePerson .

:MalePerson rdfs:subClassOf :Person .

:hasFather rdfs:subPropertyOf :hasParent .

:GrantPlinth rdf:type :Person ;
             :hasFather :MrPlinth .
